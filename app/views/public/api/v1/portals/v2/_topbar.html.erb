<% home_url = v2_home_link(@portal.slug, @portal.config['default_locale'] || params[:locale] || @locale, @design_query_param) %>
<% current = local_assigns[:current_page] || :home %>
<header class="sticky top-0 z-40 w-full bg-white dark:bg-n-slate-1 border-b border-n-weak shadow-sm font-inter tracking-normal [font-optical-sizing:auto]">
  <div class="max-w-screen-2xl w-full mx-auto flex items-center h-16 px-4 md:px-6 gap-4">
    <label for="v2-sidebar-checkbox" class="md:hidden -ml-1 p-2 rounded-lg text-n-slate-11 hover:bg-n-alpha-2 cursor-pointer" aria-label="Open sidebar">
      <span class="i-lucide-panel-left-open size-5 block" aria-hidden="true"></span>
    </label>

    <a href="<%= home_url %>" class="flex items-center min-w-0 gap-2.5">
      <% if @portal.logo.present? %>
        <img src="<%= url_for(@portal.logo) %>" class="w-8 h-8 rounded-full" draggable="false" />
      <% else %>
        <span class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-semibold text-white" style="background: <%= @portal.color %>;"><%= @portal.name.first&.upcase %></span>
      <% end %>
      <span class="text-base font-semibold tracking-tight text-n-slate-12 truncate"><%= @portal.name %></span>
      <span class="hidden sm:inline-block w-px h-5 bg-n-weak mx-1"></span>
      <span class="hidden sm:inline-block text-sm font-medium text-n-slate-11 truncate">Help Center</span>
    </a>

    <nav class="hidden md:flex items-center gap-1 ms-4" aria-label="Primary">
      <a href="<%= home_url %>"
         class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md transition <%= current == :home ? 'text-n-portal' : 'text-n-slate-11 hover:text-n-slate-12' %>">
        <%= I18n.t('public_portal.common.home') %>
      </a>
      <% if @portal.homepage_link.present? %>
        <a href="<%= @portal.homepage_link %>" target="_blank" rel="noopener noreferrer nofollow"
           class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-n-slate-11 hover:text-n-slate-12 rounded-md transition">
          Website
          <span class="i-lucide-arrow-up-right size-3.5" aria-hidden="true"></span>
        </a>
      <% end %>
    </nav>

    <div class="peer/searchbar group/searchbar hidden md:block flex-1 max-w-md mx-auto relative z-40 transition-all duration-300 ease-out focus-within:max-w-2xl">
      <div id="search-wrap"
           class="block w-full
                  [&>div]:my-0 [&>div]:max-w-none [&>div]:w-full
                  [&>div>div]:w-full [&>div>div]:h-9 [&>div>div]:!pl-3 [&>div>div]:!pr-14 [&>div>div]:!py-1 [&>div>div]:!rounded-lg
                  [&>div>div]:!bg-n-slate-1 [&>div>div]:!border-n-weak [&>div>div]:!shadow-none
                  [&>div>div]:transition-all [&>div>div]:duration-300 [&>div>div]:ease-out
                  [&>div>div]:dark:!bg-n-slate-2
                  focus-within:[&>div>div]:!h-11 focus-within:[&>div>div]:!border-n-portal focus-within:[&>div>div]:!shadow-2xl
                  [&>div>div.absolute]:!left-0 [&>div>div.absolute]:!right-0 [&>div>div.absolute]:!w-auto [&>div>div.absolute]:!top-14
                  [&_input]:text-sm [&_input]:py-0 [&_input]:!bg-transparent [&_input]:placeholder:text-n-slate-10 focus-within:[&_input]:!text-base focus-within:[&_input]:!font-440
                  [&_svg]:transition-colors focus-within:[&_svg]:text-n-portal"></div>
      <kbd class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 inline-flex items-center text-xs font-semibold text-n-slate-11 bg-n-slate-1 border border-solid border-n-weak rounded-md px-1.5 py-0.5 transition-opacity duration-200 group-focus-within/searchbar:opacity-0">⌘K</kbd>
    </div>
    <div aria-hidden="true"
         class="fixed inset-0 top-16 bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none peer-focus-within/searchbar:opacity-100 peer-focus-within/searchbar:pointer-events-auto transition-opacity duration-300 z-30"></div>

    <div class="ml-auto flex items-center gap-1.5">
      <div id="v2-theme-toggle"></div>

      <% if @portal.public_locale_codes.length > 1 %>
        <details class="hidden sm:block relative group">
          <summary class="list-none flex items-center gap-2 px-2.5 py-1.5 rounded-lg cursor-pointer text-n-slate-11 hover:text-n-slate-12 hover:bg-n-alpha-2 transition group-open:bg-n-alpha-2 group-open:text-n-slate-12 [&::-webkit-details-marker]:hidden">
            <span class="i-lucide-languages size-4" aria-hidden="true"></span>
            <span class="hidden lg:inline text-sm font-medium"><%= language_name(@locale) %></span>
            <span class="lg:hidden text-xs font-semibold uppercase"><%= @locale %></span>
            <span class="i-lucide-chevron-down size-3 opacity-60 transition-transform group-open:rotate-180" aria-hidden="true"></span>
          </summary>

          <div class="absolute right-0 top-full mt-2 bg-n-slate-1 border border-solid border-n-weak rounded-lg shadow-lg p-1 min-w-60 max-h-96 overflow-y-auto z-50">
            <div class="px-2.5 pt-2 pb-1.5 text-xs font-semibold text-n-slate-10 uppercase tracking-wider">Language</div>
            <% @portal.public_locale_codes.each do |locale| %>
              <% is_current = locale == @locale %>
              <a href="<%= append_design_query("/hc/#{@portal.slug}/#{locale}/", @design_query_param) %>"
                 class="flex items-center gap-2.5 px-2.5 py-2 text-sm rounded-md transition <%= is_current ? 'bg-n-portal-soft text-n-portal' : 'text-n-slate-11 hover:bg-n-alpha-2 hover:text-n-slate-12' %>">
                <span class="text-xs font-semibold uppercase min-w-9 text-center text-n-slate-11 bg-n-slate-2 border border-solid border-n-weak rounded px-1.5 py-0.5 flex-shrink-0"><%= locale %></span>
                <span class="flex-1 truncate <%= is_current ? 'font-medium' : '' %>"><%= language_name(locale) %></span>
                <% if is_current %>
                  <span class="i-lucide-check size-3.5 text-n-portal flex-shrink-0" aria-hidden="true"></span>
                <% end %>
              </a>
            <% end %>
          </div>
        </details>
      <% end %>
    </div>
  </div>
</header>
