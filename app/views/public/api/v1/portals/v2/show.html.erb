<%
  visible_categories = @portal.categories.where(locale: @locale).joins(:articles).where(articles: { status: :published }).order(position: :asc).group('categories.id')
  quick_categories = visible_categories.first(5)
  featured = @portal.articles.published.where(locale: @locale).order_by_views.limit(6)
%>

<%= render 'public/api/v1/portals/v2/topbar', current_page: :home %>

<div class="bg-white dark:bg-n-slate-2 flex-1 flex font-inter tracking-normal [font-optical-sizing:auto]">
  <div class="max-w-screen-2xl w-full mx-auto flex flex-1">
    <%= render 'public/api/v1/portals/v2/sidebar', current_category_slug: nil, current_article_slug: nil %>

    <main class="flex-1 min-w-0">
      <section class="relative overflow-hidden">
        <div class="absolute inset-x-0 top-0 -z-10 h-96 bg-gradient-to-b from-n-blue-3 via-n-blue-2 to-n-slate-2"></div>

        <div class="px-6 md:px-10 py-8 md:py-10">
          <h1 class="text-4xl md:text-5xl leading-tight font-620 tracking-tight text-n-slate-12 text-balance">
            <%= @portal.header_text.presence || 'How can we help?' %>
          </h1>
          <p class="mt-4 text-lg leading-normal text-n-slate-11 text-pretty">
            Search for the articles here or browse the categories below.
          </p>

          <% if quick_categories.any? %>
            <div class="mt-8 flex flex-wrap items-center gap-2">
              <% quick_categories.each do |category| %>
                <a href="<%= v2_category_link(@portal.slug, category.locale, category.slug, @design_query_param) %>"
                   class="inline-flex items-center gap-1.5 px-3.5 py-2 text-sm font-medium text-n-slate-12 bg-n-slate-1 border border-n-weak rounded-full shadow-sm hover:border-n-slate-7 hover:bg-n-alpha-2 transition">
                  <% if category.icon.present? %><span class="text-base leading-none"><%= category.icon %></span><% end %>
                  <%= category.name %>
                </a>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>

      <section class="px-6 md:px-10 py-8 md:py-10">
        <header class="mb-10">
          <h2 class="text-2xl md:text-3xl font-620 tracking-tight text-n-slate-12">Browse by topic</h2>
          <p class="mt-2 text-base text-n-slate-11">Find guides, tutorials, and answers organised by category.</p>
        </header>

        <% if visible_categories.empty? %>
          <div class="rounded-xl border border-dashed border-n-weak p-12">
            <p class="text-base text-n-slate-11"><%= I18n.t('public_portal.common.no_articles') %></p>
          </div>
        <% else %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-12">
            <% visible_categories.each do |category| %>
              <% top_articles = category.articles.published.order(:position).limit(5) %>
              <div class="flex flex-col">
                <a href="<%= v2_category_link(@portal.slug, category.locale, category.slug, @design_query_param) %>" class="flex items-center gap-3.5 group">
                  <span class="flex-shrink-0 w-12 h-12 flex items-center justify-center text-2xl rounded-xl bg-n-slate-1 border border-n-weak shadow-sm">
                    <%= category.icon.presence || '📁' %>
                  </span>
                  <h3 class="text-xl font-620 tracking-tight text-n-slate-12 group-hover:text-n-portal transition truncate"><%= category.name %></h3>
                </a>
                <% if category.description.present? %>
                  <p class="mt-3 text-base leading-relaxed text-n-slate-11 line-clamp-3"><%= category.description %></p>
                <% end %>
                <ul class="mt-4 space-y-3">
                  <% top_articles.each do |article| %>
                    <li>
                      <a href="<%= v2_article_link(@portal.slug, article.slug, @design_query_param) %>" class="group flex items-start gap-2.5 text-base text-n-slate-12 hover:text-n-portal transition">
                        <span class="i-lucide-file-text mt-1 size-3.5 flex-shrink-0 text-n-slate-10" aria-hidden="true"></span>
                        <span class="truncate"><%= article.title %></span>
                      </a>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </div>
        <% end %>
      </section>

      <% if featured.any? %>
        <section class="px-6 md:px-10 py-8 md:py-10 border-t border-n-weak">
          <header class="mb-8">
            <h2 class="text-2xl md:text-3xl font-620 tracking-tight text-n-slate-12">Popular articles</h2>
            <p class="mt-1.5 text-base text-n-slate-11">What other people are reading right now.</p>
          </header>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <% featured.each do |article| %>
              <a href="<%= v2_article_link(@portal.slug, article.slug, @design_query_param) %>" class="group flex items-start gap-3.5 p-5 rounded-xl border border-n-weak hover:border-n-slate-7 hover:bg-n-alpha-2 transition">
                <span class="flex-shrink-0 mt-0.5 w-9 h-9 flex items-center justify-center rounded-lg bg-n-alpha-2 text-n-slate-11 group-hover:bg-n-portal group-hover:text-white transition">
                  <span class="i-lucide-file-text size-4" aria-hidden="true"></span>
                </span>
                <div class="min-w-0 flex-1">
                  <h3 class="text-base font-620 text-n-slate-12 group-hover:text-n-portal transition truncate"><%= article.title %></h3>
                  <% if article.category %>
                    <p class="mt-1 text-sm text-n-slate-10 truncate"><%= article.category.icon.presence %> <%= article.category.name %></p>
                  <% end %>
                </div>
              </a>
            <% end %>
          </div>
        </section>
      <% end %>
    </main>
  </div>
</div>
