<%
  base_articles = @portal.articles.published.where(locale: @locale).includes(:author, :category)
  visible_categories = @portal.categories.where(locale: @locale).joins(:articles).where(articles: { status: :published }).order(position: :asc).group('categories.id')
  featured = base_articles.order_by_views.limit(6)
  popular_topics = visible_categories.first(3)
%>

<%= render 'public/api/v1/portals/v2/topbar', current_page: :home %>

<div class="bg-white dark:bg-n-slate-2 flex-1 flex font-inter tracking-normal [font-optical-sizing:auto]">
  <div class="max-w-screen-2xl w-full mx-auto flex flex-1">
    <%= render 'public/api/v1/portals/v2/sidebar', current_category_slug: nil, current_article_slug: nil %>

    <main class="flex-1 min-w-0">
      <section class="relative">
        <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
          <div class="absolute inset-x-0 top-0 h-[28rem] bg-gradient-to-b from-n-blue-3 via-n-blue-2 to-n-slate-2"></div>
          <div class="absolute -top-20 -right-20 h-80 w-80 rounded-full opacity-30 blur-3xl" style="background: <%= @portal.color %>;"></div>
          <div class="absolute top-32 -left-16 h-64 w-64 rounded-full opacity-20 blur-3xl" style="background: <%= @portal.color %>;"></div>
        </div>

        <div class="px-6 md:px-10 py-10 md:py-14">
          <div class="max-w-2xl">
            <h1 class="text-4xl md:text-5xl leading-tight font-620 tracking-tight text-n-slate-12 text-balance">
              <%= @portal.header_text.presence || 'How can we help?' %>
            </h1>
            <p class="mt-4 text-lg leading-normal text-n-slate-11 text-pretty">
              <%= I18n.t('public_portal.hero.sub_title') %>
            </p>

            <form class="mt-8 group/herosearch relative z-30" onsubmit="return false">
              <div id="search-wrap-hero" class="block w-full"></div>
            </form>

            <% if popular_topics.any? %>
              <div class="mt-4 flex items-center gap-2 flex-wrap text-sm">
                <span class="text-n-slate-10"><%= I18n.t('public_portal.docs.popular_label') %></span>
                <% popular_topics.each_with_index do |category, idx| %>
                  <a href="<%= v2_category_link(@portal.slug, category.locale, category.slug, @design_query_param) %>"
                     class="text-n-slate-11 hover:text-n-portal transition truncate max-w-[14rem]"><%= category.name %></a>
                  <% if idx < popular_topics.size - 1 %><span class="text-n-slate-9" aria-hidden="true">·</span><% end %>
                <% end %>
              </div>
            <% end %>

          </div>
        </div>
      </section>

      <section class="px-6 md:px-10 py-8 md:py-10">
        <header class="mb-8">
          <h2 class="text-2xl md:text-3xl font-620 tracking-tight text-n-slate-12"><%= I18n.t('public_portal.docs.browse_by_topic') %></h2>
          <p class="mt-2 text-base text-n-slate-11"><%= I18n.t('public_portal.docs.browse_by_topic_subtitle') %></p>
        </header>

        <% if visible_categories.empty? %>
          <div class="rounded-xl border border-dashed border-n-weak p-12">
            <p class="text-base text-n-slate-11"><%= I18n.t('public_portal.common.no_articles') %></p>
          </div>
        <% else %>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <% visible_categories.each do |category| %>
              <%
                cat_articles = category.articles.published.includes(:author)
                contributor_avatars = cat_articles.map(&:author).compact.uniq.first(3)
              %>
              <a href="<%= v2_category_link(@portal.slug, category.locale, category.slug, @design_query_param) %>"
                 class="group relative flex flex-col p-5 rounded-xl border border-solid border-n-weak hover:border-n-portal hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
                <span class="flex-shrink-0 w-11 h-11 flex items-center justify-center text-2xl rounded-xl bg-n-slate-2 border border-solid border-n-weak">
                  <%= category.icon.presence || '📁' %>
                </span>
                <h3 class="mt-4 text-lg font-620 tracking-tight text-n-slate-12 group-hover:text-n-portal transition"><%= category.name %></h3>
                <% if category.description.present? %>
                  <p class="mt-1.5 text-sm leading-relaxed text-n-slate-11"><%= category.description %></p>
                <% end %>
                <div class="mt-auto pt-5 flex items-center justify-between">
                  <% if contributor_avatars.any? %>
                    <span class="flex">
                      <% contributor_avatars.each_with_index do |author, idx| %>
                        <% offset_class = idx.positive? ? '-ml-1.5' : '' %>
                        <% if author.avatar_url.present? %>
                          <img src="<%= author.avatar_url %>" alt="<%= author.available_name %>" class="w-6 h-6 rounded-full object-cover ring-2 ring-solid ring-white dark:ring-n-slate-2 <%= offset_class %>" title="<%= author.available_name %>" />
                        <% else %>
                          <span class="w-6 h-6 rounded-full inline-flex items-center justify-center text-xs font-semibold text-white ring-2 ring-solid ring-white dark:ring-n-slate-2 <%= offset_class %>" style="background: <%= thumbnail_bg_color(author.available_name) %>;" title="<%= author.available_name %>"><%= author.available_name.first&.upcase %></span>
                        <% end %>
                      <% end %>
                    </span>
                  <% else %>
                    <span></span>
                  <% end %>
                  <span class="inline-flex items-center gap-1 text-sm font-medium text-n-slate-11 group-hover:text-n-portal transition">
                    <%= I18n.t('public_portal.docs.browse') %>
                    <span class="i-lucide-arrow-right size-3.5 group-hover:translate-x-0.5 transition-transform" aria-hidden="true"></span>
                  </span>
                </div>
              </a>
            <% end %>
          </div>
        <% end %>
      </section>

      <% if featured.size > 1 %>
        <section class="px-6 md:px-10 py-8 md:py-10 border-t border-n-weak">
          <header class="mb-8">
            <h2 class="text-2xl md:text-3xl font-620 tracking-tight text-n-slate-12"><%= I18n.t('public_portal.docs.popular_articles') %></h2>
            <p class="mt-1.5 text-base text-n-slate-11"><%= I18n.t('public_portal.docs.popular_articles_subtitle') %></p>
          </header>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% featured.each do |article| %>
              <a href="<%= v2_article_link(@portal.slug, article.slug, @design_query_param) %>" class="group flex flex-col p-5 rounded-xl border border-solid border-n-weak hover:border-n-portal hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
                <% if article.category %>
                  <span class="inline-flex items-center gap-1 self-start text-xs font-medium text-n-slate-11 mb-3">
                    <% if article.category.icon.present? %><span><%= article.category.icon %></span><% end %>
                    <%= article.category.name %>
                  </span>
                <% end %>
                <h3 class="text-base font-620 text-n-slate-12 group-hover:text-n-portal transition"><%= article.title %></h3>
                <p class="mt-2 text-sm leading-relaxed text-n-slate-11 line-clamp-2"><%= render_category_content(article.content) %></p>
              </a>
            <% end %>
          </div>
        </section>
      <% end %>

      <%= render 'public/api/v1/portals/v2/footer' %>
    </main>
  </div>
</div>
